# Haulyard API — copy to repo root .env for local dev, or set as container/host env in production

NODE_ENV=development
API_PORT=3001
PORT=3001

DATABASE_URL=postgresql://haulyard:haulyard_secret@localhost:5432/haulyard
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-min-32-chars-in-production
JWT_REFRESH_SECRET=change-me-min-32-chars-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

FRONTEND_URL=http://localhost:3000
# Optional: extra allowed origins, comma-separated
CORS_ORIGINS=

# Set true only when the web app and API are served from different domains
CROSS_SITE_COOKIES=false

# Documents (required in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=haulyard-documents

SEED_DEMO=false
SENTRY_DSN=
