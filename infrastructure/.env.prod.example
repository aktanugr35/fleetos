# Copy to infrastructure/.env.prod and fill before: docker compose -f infrastructure/docker-compose.prod.yml up --build
#
# Generate JWT secrets (32+ chars):
#   openssl rand -base64 48

# Internal Postgres credentials. Existing VPS installs often keep fleetos; new installs may use haulyard.
POSTGRES_DB=fleetos
POSTGRES_USER=fleetos
POSTGRES_PASSWORD=change-me-strong-postgres-password

NODE_ENV=production
API_PORT=3001
WEB_PORT=3000

# VPS (one domain + Nginx): use the same public URL for both
FRONTEND_URL=https://panel.valleytransusa.com
NEXT_PUBLIC_API_URL=https://panel.valleytransusa.com
CROSS_SITE_COOKIES=false

# Local Docker smoke test:
# FRONTEND_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:3001

DATABASE_URL=postgresql://fleetos:change-me-strong-postgres-password@db:5432/fleetos
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-48-chars-minimum
JWT_REFRESH_SECRET=replace-with-another-openssl-rand-base64-48-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Required in production (documents). Use AWS S3 or Cloudflare R2 (S3-compatible).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
S3_BUCKET_NAME=haulyard-documents
# For Cloudflare R2 only — set to https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=

SEED_DEMO=false

# Optional error reporting
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

RESEND_API_KEY=
FROM_EMAIL=noreply@haulyard.app
