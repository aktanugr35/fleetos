# ============================================
# Haulyard — Environment Variables
# ============================================

# Database
DATABASE_URL=postgresql://haulyard:haulyard_secret@localhost:5432/haulyard

# Redis
REDIS_URL=redis://localhost:6379

# JWT (use openssl rand -base64 48 for production — min 32 characters)
JWT_ACCESS_SECRET=haulyard-dev-access-secret-change-in-production
JWT_REFRESH_SECRET=haulyard-dev-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AWS S3 / Cloudflare R2 (optional in development — required in staging/production)
# When both AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are set, documents use S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=haulyard-documents

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=noreply@haulyard.app

# App
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000

# Demo seed (development only — blocked when NODE_ENV=production|staging)
SEED_DEMO=false

# Error reporting (optional)
SENTRY_DSN=
